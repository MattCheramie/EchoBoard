# EchoBoard configuration — copy to `.env` and adjust.
# These are placeholders for Tier 1 (config + DB). Nothing reads them yet.

# ---- Server ----
PORT=8080
# development | production
APP_ENV=development

# ---- Database ----
# Driver: sqlite (local-first default) or postgres (VPS/production)
DB_DRIVER=sqlite
# For sqlite: path to the database file.
# For postgres: a DSN such as postgres://user:pass@localhost:5432/echoboard?sslmode=disable
DATABASE_URL=./echoboard.db

# ---- Security ----
# 32-byte base64 key used to encrypt integration tokens/keys at rest (Tier 1).
# Generate with: openssl rand -base64 32
SECRET_KEY=change-me-generate-a-real-key

# ---- Frontend ----
# Base URL the frontend uses to reach the API in dev.
PUBLIC_API_BASE_URL=http://localhost:8080

# ---- Integrations (Tier 4) ----
# Each platform's OAuth app credentials and webhook secret are operator-supplied
# (register an app with the provider). The built-in `sandbox` adapter needs no
# credentials except an optional webhook secret for signed test webhooks.
# Pattern: INTEGRATION_<PLATFORM>_{CLIENT_ID,CLIENT_SECRET,WEBHOOK_SECRET,REDIRECT_URI}
# INTEGRATION_SANDBOX_WEBHOOK_SECRET=change-me
# INTEGRATION_META_CLIENT_ID=
# INTEGRATION_META_CLIENT_SECRET=
# INTEGRATION_META_WEBHOOK_SECRET=
# INTEGRATION_META_REDIRECT_URI=https://your-host/api/integrations/meta/callback
